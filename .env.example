# Supabase project URL — Settings → API → Project URL
SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# SECRET. Settings → API → service_role key.
# Никогда не коммитьте, никогда не отправляйте в браузер.
# Это JWT-токен, начинается с "eyJ..." (НЕ "sb_publishable_...")
SUPABASE_SERVICE_KEY=eyJhbGciOiJI...service_role...

# Render задаёт PORT сам, локально можно переопределить
PORT=3000
